# URL do endpoint GraphQL do WordPress
# Copie para .env e ajuste conforme o ambiente (dev, homologação, produção)
NUXT_API_URL=https://www.brasilcenter.com.br/wordpress/graphql

# Opcional: se aparecer erro de certificado SSL (UNABLE_TO_VERIFY_LEAF_SIGNATURE) em dev,
# o código já ignora verificação em desenvolvimento. Só use em último caso:
# NODE_TLS_REJECT_UNAUTHORIZED=0
