<?xml version="1.0" encoding="UTF-8"?>
<!--
    Web.config para Brasil Center - IIS
    
    INSTRUÇÕES DE INSTALAÇÃO:
    1. Renomeie este arquivo de "__web.config" para "web.config"
    2. Site na raiz, WordPress na pasta /wp - configuração ideal!
    3. Verifique se o PHP já está configurado no IIS antes de descomentar a seção de handlers
    4. Teste as URLs: /sobre-bcc e /jeito-bcc
    
    ESTRUTURA DO SITE:
    - Site Brasil Center: / (raiz)
    - WordPress: /wp/
    - Sem conflitos de rewrite rules
    
    COMPATIBILIDADE:
    - Totalmente compatível com WordPress em /wp
    - Otimizado para performance com cache e compressão
    - Headers de segurança incluídos
    
    CACHE E DESENVOLVIMENTO:
    - Se houver problemas de cache durante desenvolvimento, limpe o cache do navegador
    - Em produção, o cache melhora significativamente a performance
    - O sistema de cache interno está na pasta /cache (protegida pelo web.config)
-->
<configuration>
    <system.webServer>
        <!-- URL Rewrite para URLs limpas (equivalente ao .htaccess) -->
        <rewrite>
            <rules>
                <!-- Ignorar pasta do WordPress - deixar passar direto -->
                <rule name="WordPress Folder" stopProcessing="true">
                    <match url="^wordpress(/.*)?$" />
                    <action type="None" />
                </rule>
                
                <!-- Redirecionar URLs com .php para URLs limpas -->
                <rule name="Redirect PHP URLs" stopProcessing="true">
                    <match url="^(.*?)\.php$" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" />
                        <add input="{THE_REQUEST}" pattern=" /+[^?]*?\.php[\s?]" />
                        <!-- Não aplicar para pasta wp -->
                        <add input="{URL}" pattern="^/wordpress/" negate="true" />
                    </conditions>
                    <action type="Redirect" url="{R:1}" redirectType="Permanent" />
                </rule>
                
                <!-- Reescrever URLs limpas para .php -->
                <rule name="Clean URLs" stopProcessing="true">
                    <match url="^(sobre|jeito-bcc)/?$" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="{R:1}.php" />
                </rule>
                
                <!-- Página inicial -->
                <rule name="Home Page" stopProcessing="true">
                    <match url="^$" />
                    <action type="Rewrite" url="index.php" />
                </rule>
            </rules>
        </rewrite>
        
        <!-- Compressão (equivalente ao GZIP do Apache) -->
        <urlCompression doDynamicCompression="true" doStaticCompression="true" />
        <httpCompression>
            <dynamicTypes>
                <add mimeType="text/html" enabled="true" />
                <add mimeType="text/css" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="text/javascript" enabled="true" />
                <add mimeType="application/json" enabled="true" />
                <add mimeType="text/xml" enabled="true" />
                <add mimeType="application/xml" enabled="true" />
                <add mimeType="image/svg+xml" enabled="true" />
            </dynamicTypes>
            <staticTypes>
                <add mimeType="text/css" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="text/javascript" enabled="true" />
                <add mimeType="image/svg+xml" enabled="true" />
                <add mimeType="application/font-woff" enabled="true" />
                <add mimeType="application/font-woff2" enabled="true" />
            </staticTypes>
        </httpCompression>
        
        <!-- Cache Headers (equivalente ao Apache) -->
        <staticContent>
            <!-- Cache de 1 ano para recursos estáticos - Ajustar conforme ambiente -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            
            <!-- MIME Types para fontes e outros recursos -->
            <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
            <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
            <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
            <mimeMap fileExtension=".json" mimeType="application/json" />
        </staticContent>
        
        <!-- Headers de Segurança -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <add name="X-XSS-Protection" value="1; mode=block" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Configurações de erro personalizadas -->
        <httpErrors errorMode="Custom" existingResponse="Replace">
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" path="/404.php" responseMode="ExecuteURL" />
        </httpErrors>
        
        <!-- Configurações de performance -->
        <caching enabled="true" enableKernelCache="true">
            <profiles>
                <!-- Cache para recursos estáticos -->
                <add extension=".css" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".js" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".png" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".jpg" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".jpeg" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".gif" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".svg" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".ico" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".woff" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                <add extension=".woff2" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" duration="365.00:00:00" />
                
                <!-- Cache menor para HTML/PHP -->
                <add extension=".html" policy="CacheUntilChange" kernelCachePolicy="DontCache" duration="01:00:00" />
                <add extension=".php" policy="DontCache" kernelCachePolicy="DontCache" />
            </profiles>
        </caching>
        
        <!-- Configurações do PHP - Usar apenas se não estiver configurado globalmente -->
        <!-- 
        <handlers>
            <add name="PHP" path="*.php" verb="*" modules="FastCgiModule" scriptProcessor="C:\php\php-cgi.exe" resourceType="File" />
        </handlers>
        -->
        
        <!-- Configurações de segurança adicionais -->
        <security>
            <requestFiltering>
                <!-- Limitar tamanho de upload -->
                <requestLimits maxAllowedContentLength="52428800" /> <!-- 50MB -->
                
                <!-- Bloquear extensões perigosas -->
                <fileExtensions>
                    <add fileExtension=".config" allowed="false" />
                    <add fileExtension=".log" allowed="false" />
                    <add fileExtension=".cache" allowed="false" />
                </fileExtensions>
                
                <!-- Bloquear URLs perigosas -->
                <hiddenSegments>
                    <add segment="cache" />
                    <add segment="includes" />
                    <add segment=".git" />
                    <add segment=".env" />
                    <!-- Pasta wp não bloqueada - WordPress precisa ser acessível -->
                </hiddenSegments>
            </requestFiltering>
        </security>
        
        <!-- Configurações de módulos -->
        <modules>
            <remove name="WebDAVModule" />
        </modules>
        
        <!-- Configurações de default documents -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
                <add value="index.html" />
            </files>
        </defaultDocument>
    </system.webServer>
    
    <!-- Configurações do sistema -->
    <system.web>
        <!-- Configurações de compilação -->
        <compilation debug="false" targetFramework="4.0" />
        
        <!-- Configurações de sessão -->
        <httpRuntime maxRequestLength="51200" executionTimeout="300" />
        
        <!-- Configurações de globalização -->
        <globalization culture="pt-BR" uiCulture="pt-BR" />
    </system.web>
</configuration>
